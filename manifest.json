{
  "manifest_version": 3,
  "name": "easy cookies importer",
  "version": "1.0",
  "description": "Import cookies from clipboard or file.",
  "icons": {
    "96": "icon.png"
  },
  "permissions": [
    "cookies",
    "tabs",
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "easy cookies importer"
  }
}
